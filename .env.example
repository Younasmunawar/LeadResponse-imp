PORT=3000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/kenny_gemini?retryWrites=true&w=majority

# Gemini transcript/answer analysis
# Create keys in Google AI Studio. Never expose them in frontend JavaScript.
# Primary is required. Secondary is optional and used automatically when the
# primary key is rate-limited or temporarily unavailable.
GEMINI_API_KEY_PRIMARY=your_primary_gemini_api_key
GEMINI_API_KEY_SECONDARY=your_secondary_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Optional backward-compatible single-key variable. Leave blank when using the
# primary/secondary variables above.
GEMINI_API_KEY=

# Brevo HTTPS transactional email API
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=your_verified_sender@example.com
EMAIL_FROM_NAME=Kenny Voice Agent
EMAIL_TO=first_receiver@example.com,second_receiver@example.com

# Optional legacy Vapi compatibility. The prerecorded browser flow does not require these.
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# Optional retry controls. When both Gemini keys are temporarily unavailable,
# the backend waits and retries. Defaults: 3 rounds and 5-second base delay.
GEMINI_RETRY_ROUNDS=3
GEMINI_RETRY_DELAY_MS=5000
