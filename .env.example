PORT=3000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/kenny_gemini?retryWrites=true&w=majority

# Gemini: local-first validation with separate key pools
# Live answer validation uses these three keys sequentially. Each key gets a
# strict 2-second default timeout, so Gemini validation can take at most 6s.
GEMINI_VALIDATION_KEY_1=your_validation_key_1
GEMINI_VALIDATION_KEY_2=your_validation_key_2
GEMINI_VALIDATION_KEY_3=your_validation_key_3

# Final call analysis uses these two separate keys. Each gets a 5-second
# default timeout. If both fail, the lead is finalized with local data.
GEMINI_FINALIZATION_KEY_1=your_finalization_key_1
GEMINI_FINALIZATION_KEY_2=your_finalization_key_2

GEMINI_MODEL=gemini-2.5-flash
GEMINI_VALIDATION_TIMEOUT_MS=2000
GEMINI_FINALIZATION_TIMEOUT_MS=5000

# Legacy variables remain supported for older deployments, but the five
# dedicated variables above are recommended.
GEMINI_API_KEY_PRIMARY=
GEMINI_API_KEY_SECONDARY=
GEMINI_API_KEY=

# Brevo HTTPS transactional email API
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=your_verified_sender@example.com
EMAIL_FROM_NAME=Kenny Voice Agent
EMAIL_TO=first_receiver@example.com,second_receiver@example.com

# Optional legacy Vapi compatibility. The prerecorded browser flow does not require these.
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# Private demo access code (defaults to LEAD2026 when omitted)
DEMO_ACCESS_CODE=LEAD2026
